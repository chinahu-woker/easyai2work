	Kongzhitai()
}, { deep: true })

// 监听权限变化，自动调整当前页面索引
watch(() => tabbarData?.value, (newTabbarData, oldTabbarData) => {
	// 如果 tabbar 配置改变了（通常是权限变化导致），需要检查当前页面索引是否仍然有效
	if (newTabbarData && oldTabbarData && newTabbarData.length !== oldTabbarData.length) {
		// 如果当前页面索引超出了新的 tabbar 范围，重置到首页
		if (pageindex.value >= newTabbarData.length) {
			console.log('页面索引超出范围，重置到首页')
			pageindex.value = 0
		}
	}
}, { deep: true })

// 监听登录状态变化，确保页面正确显示
watch(() => isLogin?.value, (newLoginStatus) => {
	console.log('登录状态变化:', newLoginStatus)
	try {
		// 如果用户登出，可能导致 tabbar 过滤变化（例如门店项被移除），需要修正当前 pageindex
		if (newLoginStatus === false) {
			const currentTab = tabbarData.value && tabbarData.value[pageindex.value] ? tabbarData.value[pageindex.value] : null
			// 如果当前 tab 已不存在或当前用户无权访问，重置到首页
			if (!currentTab || !checkPagePermission(currentTab)) {
				console.log('当前页面对未登录用户不可见，重置到首页')
				pageindex.value = 0
				// 二次校验：如果首页也不可见（极端情况），把最后一项设置为登录页索引（如果存在）
				const homeTab = tabbarData.value && tabbarData.value[0] ? tabbarData.value[0] : null
				if (!homeTab || !checkPagePermission(homeTab)) {
					const length = tabbarData.value ? tabbarData.value.length : 0
					const lastIndex = Math.max(0, length - 1)
					pageindex.value = lastIndex
				}
			}
		}
	} catch (e) {
		console.error('处理登录状态变化出错:', e)
	}
})

