// 使用模块级 appStore，避免重复创建 store 实例
const { tabbarIndex } = storeToRefs(appStore)
const pageindex = ref(0)

// 检查用户是否有访问指定页面的权限
const checkPagePermission = (pageConfig: any) => {
	try {
		// 如果页面没有配置 organizations 或为空数组，表示所有人都可以访问
		if (!pageConfig.organizations || !Array.isArray(pageConfig.organizations) || pageConfig.organizations.length === 0) {
			return true
		}

		const requiredOrgs = pageConfig.organizations

		// 如果 organizations 包含 "None"，表示未登录用户也可以访问
		if (requiredOrgs.includes("None")) {
			return true
		}

		// 如果用户未登录，且没有 "None" 权限，无法访问有权限要求的页面
		if (!isLogin.value || !user.value || !Array.isArray(user.value?.organizations)) {
			return false
		}

		const userOrgs = user.value.organizations

		// 检查用户的组织ID列表是否与页面要求的组织ID有交集
		return userOrgs.some((userOrgId: string) => requiredOrgs.includes(userOrgId))
	} catch (e) {
		console.error('检查页面权限时出错:', e)
		return false
	}
}

// 为兼容现有逻辑，保留 isOrgAllowed 计算属性（专门用于检查门店权限）
const isOrgAllowed = computed(() => {
	const storeTab = globalTabbarData.find((it: any) => {
		const text = (typeof it.text === 'string') ? it.text : (it.text && it.text.value) || ''
		return text === '门店'
	})
	return storeTab ? checkPagePermission(storeTab) : false
})

const changeHomePage = (payload: any) => {
	// payload 可能是数字或带 index 字段的对象，兼容两者
	const idx = typeof payload === 'number' ? payload : (payload && payload.index !== undefined ? payload.index : payload)
	const target = Number(idx) || 0

	// 获取当前过滤后的 tabbar 配置
	const currentTabbarData = tabbarData.value

	// 检查目标索引是否有效
	if (!currentTabbarData || target >= currentTabbarData.length) {
		console.warn('目标页面索引超出范围:', target)
		return
	}

	// 获取目标页面配置
	const targetPageConfig = currentTabbarData[target]
	if (!targetPageConfig) {
		console.warn('目标页面配置不存在:', target)
		return
	}

	// 处理未登录状态下点击登录页
	const targetText = (typeof targetPageConfig.text === 'string') ? targetPageConfig.text : (typeof targetPageConfig.text === 'object' && targetPageConfig.text !== null ? String(targetPageConfig.text) : '') || ''
	if (!isLogin.value && targetText === '登录') {
		handleLogin()
		return
	}

	// 设置页面索引
	pageindex.value = target
	
	console.log('切换到页面:', {
		index: pageindex.value, 
		text: targetText,
		contentType: getPageContentType(target)
	});
};


const name_value = ref('我的')
// 移除旧的 wode_loging 函数，使用新的权限控制逻辑
// 使用全局配置的 tabbarData，基于权限动态过滤（无权限则隐藏“门店”项），并把最后一项的 text 替换为响应式 name_value
const tabbarData = computed(() => {
	// 深拷贝避免直接修改全局配置对象
	const arr = globalTabbarData.map((item: any) => ({ ...item }))

	// 如果没有组织访问权限，过滤掉文本为“门店”的项
	const filtered = arr.filter((item: any) => {
		return checkPagePermission(item)
	})

	// 未登录时，确保有登录入口：将最后一项改为登录页
	if (!isLogin.value && filtered.length > 0) {
		const lastIndex = filtered.length - 1
		filtered[lastIndex] = {
			...filtered[lastIndex],
			text: '登录',
			onClick: tabbarIndex
		}
	} else if (isLogin.value && filtered.length > 0) {
		// 已登录时，最后一项显示为"我的"
		const lastIndex = filtered.length - 1
		filtered[lastIndex] = {
			...filtered[lastIndex],
			text: '我的',
			onClick: tabbarIndex
		}
	}

	console.log('过滤后的 tabbar 配置:', filtered, '登录状态:', isLogin.value)

	return filtered
})

// 创建页面内容的动态映射逻辑
// 优先使用配置字段 `tabText`（稳定键），如果不存在再回退到 `text`（中文展示名）
const getPageContentType = (currentIndex: number) => {
	const currentTabbar = tabbarData.value
	if (!currentTabbar || currentIndex >= currentTabbar.length) return 'home'

	const currentTab = currentTabbar[currentIndex]
	if (!currentTab) return 'home'

	// 优先读取稳定的键名 tabText（例如 'home'|'store'|'profile'），否则回退到中文 text
	const tabKey = (typeof currentTab.tabText === 'string' && currentTab.tabText.trim() !== '')
		? currentTab.tabText.trim()
		: ((typeof currentTab.text === 'string') ? currentTab.text.trim() : (currentTab.text && typeof currentTab.text !== 'object' ? String(currentTab.text) : ''))

	// 根据 tabKey 决定页面内容类型（支持两种风格的配置）
	// 支持：tabText: 'home'|'store'|'profile' 或 text: '主页'|'门店'|'我的'|'登录'
	if (tabKey === 'home' || tabKey === '主页') return 'home'
	if (tabKey === 'store' || tabKey === '门店') return 'store'
	if (tabKey === 'profile' || tabKey === '我的' || tabKey === '登录') return 'profile'

	// 默认返回主页
	return 'home'
}

// 计算当前页面内容类型
const currentPageType = computed(() => {
	const contentType = getPageContentType(pageindex.value)
	console.log('当前页面类型:', {
		pageindex: pageindex.value,
		contentType,
		tabbarData: tabbarData.value,
		isLogin: isLogin.value
	})
	return contentType
})
const getFilteredIndex = (originalIndex: number) => {
	// originalIndex 是基于 globalTabbarData 的索引（未过滤前）
	const originalConfig = globalTabbarData[originalIndex]
	if (!originalConfig) return -1

	const filteredConfigs = tabbarData.value

	// 规范化函数，返回优先 tabText，否则 text 的小写形式
	const normalize = (cfg: any) => {
		if (!cfg) return ''
		if (typeof cfg.tabText === 'string' && cfg.tabText.trim() !== '') return cfg.tabText.trim().toLowerCase()
		if (typeof cfg.text === 'string' && cfg.text.trim() !== '') return cfg.text.trim().toLowerCase()
		return ''
	}

	const originalKey = normalize(originalConfig)
	if (!filteredConfigs) return -1
	
	for (let i = 0; i < filteredConfigs.length; i++) {
		const filteredKey = normalize(filteredConfigs[i])

		// 直接匹配稳定键或中文展示名
		if (originalKey && filteredKey && originalKey === filteredKey) return i

		// 容错：原始为 '我的'，过滤后可能是 '登录'（未登录场景），也视为匹配
		if (originalKey === '我的' && filteredKey === '登录') return i
		if (originalKey === '我的' && filteredKey === '我的') return i

		// 也支持原始使用 'profile' 等键的情况
		if (originalKey === 'profile' && (filteredKey === '我的' || filteredKey === '登录' || filteredKey === 'profile')) return i
	}

	// 未找到匹配项，返回 -1
	return -1
}

const backGroundImage = computed(() => {
	return globalBackGroundImage || 'https://chinahu-ai-server.oss-cn-chengdu.aliyuncs.com/aidraw/image/temps/67873d6c232a3c5d52240dd6/Home2.jpg'
})


// ---------------------------------------------------------



// -------------------------------------------------------

// 扫码登录功能

function scanQrLogin() {
	if (!isLogin.value){
		// 提示并跳转到登录页，改善用户体验
		uni.showToast({ title: '请先登录', icon: 'none' })
		uni.navigateTo({ url: '/pages/login/login' })
		return
	}
	// 直接调用扫码功能
	if (typeof uni.scanCode !== 'function') {
		uni.showToast({ title: '当前环境不支持扫码', icon: 'none' })
		return
	}
	
	uni.scanCode({
		success: async (res) => {
			const raw = res.result || ''
			let token = ''
			
			// 解析扫码结果
			if (/^https?:\/\//i.test(raw)) {
				try {
					const url = new URL(raw)
					token = url.searchParams.get('token') || url.searchParams.get('qr_token') || ''
					if (!token) {
						const hash = url.hash.replace(/^#/, '')
						if (hash.startsWith('token=')) token = hash.split('=')[1]
					}
				} catch (e) {
					// URL解析失败，当作纯token处理
				}
			}
			
			if (!token) token = raw.trim()
			if (!token) {
				uni.showToast({ title: '未识别到有效的登录码', icon: 'none' })
				return
			}
			
			// 跳转到扫码登录页面并传递token
			uni.navigateTo({
				url: `/pages/login/Qr_login?qr_token=${encodeURIComponent(token)}`
			})
		},
		fail: () => {
			uni.showToast({ title: '扫码失败', icon: 'none' })
		}
	})
}

function toEmpty() {
	// 需要登录后才能访问扫码登录页面（管理端扫码）
	if (!isLogin.value) {
		uni.showToast({ title: '请先登录', icon: 'none' })
		uni.navigateTo({ url: '/pages/login/login' })
		return
	}

	// 跳转到扫码登录页面（二维码登录）
	uni.navigateTo({ url: '/pages/login/Qr_login' })
}
