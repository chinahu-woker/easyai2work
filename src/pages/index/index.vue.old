			title: '我分享了一个作品，真的太棒了！',
			path: `/pages/index/index?pageindex=2&inviteCode=${inviteCode}`,
		}
	}

	return {
		title: globalAppData.share.appInfo,
		path: `/pages/index/index?inviteCode=${inviteCode}`,
	}
})
