  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
}
.circle.data-v-96383370 {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #f2f3f5;
}
.ring.data-v-96383370 {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  height: 80%;
  border-radius: 50%;
  border: 10rpx solid #d9e0e9;
}

