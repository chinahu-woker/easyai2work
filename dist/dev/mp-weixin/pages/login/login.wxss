}

	/* 登录表单容器 */
.login-form.data-v-cdfe2409 {
		width: 100%;
		max-width: 550rpx;
		/* 限制最大宽度，避免大屏拉伸 */
		display: flex;
		flex-direction: column;
		gap: 30rpx;
}

	/* 输入框容器 - 添加底部边框和聚焦效果 */
.form-group.data-v-cdfe2409 {
		display: flex;
		flex-direction: column;
		gap: 20rpx;
		/* 维持输入框间距 */
}

	/* 输入框基础样式 */
.data-v-cdfe2409 .fui-input {
		height: 210rpx;
		border-radius: 5rpx;
		/* 增加圆角半径 */
		background-color: rgba(255, 255, 255, 0.98);
		/* 更通透的白色 */
		padding: 0 30rpx;
		/* 底部边框替代全边框，更简洁 */
		border-bottom: 2rpx solid #E0E0E0;
		/* 更新底边颜色 */
		border-top: none !important;
		border-left: none !important;
		border-right: none !important;
		box-shadow: none !important;
		/* 去掉厚重阴影 */
		font-size: 32rpx;
		/* 适中字体大小 */
		display: flex;
		align-items: center;
		/* 文字垂直居中 */
}

	/* 输入框聚焦效果 */
.data-v-cdfe2409 .fui-input:focus {
		border-bottom-color: #4A90E2 !important;
		/* 使用更鲜明的颜色 */
		/* 底部轻微发光效果，增强聚焦感 */
		box-shadow: 0 2rpx 10rpx rgba(74, 144, 226, 0.3) !important;
}

	/* 输入框占位符样式 */
.data-v-cdfe2409 .fui-input input::-moz-placeholder {
		color: #B0B0B0;
		font-size: 32rpx;
		letter-spacing: 0.5rpx;
		/* 轻微 letter-spacing 更精致 */
}
.data-v-cdfe2409 .fui-input input::placeholder {
		color: #B0B0B0;
		font-size: 32rpx;
		letter-spacing: 0.5rpx;
		/* 轻微 letter-spacing 更精致 */
}

	/* 输入框文字样式 */
.data-v-cdfe2409 .fui-input input {
		color: #333;
		font-size: 32rpx;
		line-height: 1.5;
		/* 调整行高 */
		width: 100%;
}

	/* 错误提示位置调整 - 与输入框对齐 */
.error-text.data-v-cdfe2409 {
		color: #FF5252;
