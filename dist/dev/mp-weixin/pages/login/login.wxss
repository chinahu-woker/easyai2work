	/* 背景图全屏覆盖 */
.bg-image.data-v-cdfe2409 {
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		z-index: -1;
		background-size: cover;
		/* 覆盖全屏 */
		background-position: center;
