}
.login-container.data-v-cdfe2409 {
		padding: 30rpx 40rpx;
		/* 增大边距，避免内容贴边 */
		min-height: 100vh;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		/* 整体内容居中 */
}

	/* 导航栏 */
.nav-bar.data-v-cdfe2409 {
		width: 100%;
		margin-top: 20rpx;
		padding-left: 10rpx;
}

	/* 欢迎标题区域 */
.welcome-section.data-v-cdfe2409 {
		margin: 120rpx 0 80rpx;
		/* 调整顶部距离，更靠下 */
		text-align: center;
		width: 100%;
}
.welcome-title.data-v-cdfe2409 {
		font-size: 52rpx;
		/* 增大标题字号 */
