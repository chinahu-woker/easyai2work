
/* 基础布局优化 */
.page-container.data-v-12565c11 {
    min-height: 100vh;
    background-color: #f9f9f9;
    padding: 30rpx 20rpx;
    box-sizing: border-box;
}

/* Logo样式优化 - 居中显示并增加间距 */
.logo-wrapper.data-v-12565c11 {
    display: flex;
    justify-content: center;
    margin: 60rpx 0 40rpx; /* 顶部和底部间距 */
}
.logoSty.data-v-12565c11 {
    width: 320rpx;
    height: 160rpx;
    -o-object-fit: contain;
       object-fit: contain; /* 保持图片比例 */
	margin-bottom: -10%;
	margin-top: 20%;
}

/* 注册容器样式合并优化 */
.register-container.data-v-12565c11 {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20rpx 0;
}

/* 表单卡片样式增强 */
.register-form.data-v-12565c11 {
    width: 90%;
    max-width: 600rpx;
    background-color: #fff;
    padding: 60rpx 40rpx;
    border-radius: 24rpx; /* 更大圆角更柔和 */
    box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.08); /* 增强阴影层次感 */
    animation: fadeIn-12565c11 0.5s ease-out; /* 动画更自然 */
}

/* 标题样式优化 */
.form-title.data-v-12565c11 {
    font-size: 40rpx;
    font-weight: 600;
    color: #6C5CE7;
    text-align: center;
    margin-bottom: 60rpx;
    letter-spacing: 2rpx; /* 增加字间距 */
}

/* 表单组间距优化 */
.form-group.data-v-12565c11 {
    display: flex;
    flex-direction: column;
    gap: 30rpx; /* 统一输入项间距 */
}

/* 输入框样式微调 */
fui-input.data-v-12565c11 {
    margin-bottom: 10rpx; /* 输入框与错误提示的间距 */
    height: 90rpx; /* 增加输入框高度，更易点击 */
    border-radius: 12rpx; /* 输入框圆角 */
}

/* 错误提示样式优化 */
.error-text.data-v-12565c11 {
    color: #FF4D4D;
    font-size: 24rpx;
    margin-top: -20rpx; /* 贴近输入框 */
    margin-bottom: 10rpx;
    margin-left: 10rpx; /* 与输入框左对齐 */
    line-height: 1.4;
}

/* 协议区域样式优化 */
.agreement-group.data-v-12565c11 {
    display: flex;
    align-items: center;
    margin-top: 20rpx;
    padding: 10rpx 0;
}
.agreement-text.data-v-12565c11 {
    color: #555; /* 稍浅颜色更舒适 */
    font-size: 24rpx;
    margin-left: 15rpx;
    line-height: 1.5;
}
.agreement-link.data-v-12565c11 {
    color: #6C5CE7;
    -webkit-text-decoration: underline;
    text-decoration: underline;
    margin: 0 4rpx;
    transition: all 0.3s ease;
}

/* 按钮区域样式优化 */
.form-actions.data-v-12565c11 {
    margin-top: 50rpx;
    display: flex;
    flex-direction: column;
    gap: 30rpx;
}

/* 注册按钮样式增强 */
.register-button.data-v-12565c11 {
    width: 100%;
    height: 100rpx; /* 更高按钮更易点击 */
    background-color: #6C5CE7;
    color: #fff;
    border: none;
    border-radius: 16rpx; /* 大圆角更友好 */
    font-size: 32rpx;
    font-weight: 500;
    transition: all 0.3s ease; /* 过渡更流畅 */
    letter-spacing: 2rpx;
}
.register-button.data-v-12565c11:disabled {
    background-color: #E0E0E0;
    color: #9E9E9E;
    cursor: not-allowed;
}

/* 切换登录链接样式优化 */
.switch-mode.data-v-12565c11 {
    display: block;
    color: #6C5CE7;
    font-size: 28rpx;
    text-align: center; /* 居中显示更平衡 */
    cursor: pointer;
    padding: 10rpx 0;
    transition: color 0.3s ease;
}

/* 动画效果优化 */
@keyframes fadeIn-12565c11 {
from {
        opacity: 0;
        transform: translateY(30rpx); /* 稍大位移更明显 */
}
to {
        opacity: 1;
        transform: translateY(0);
}
}
